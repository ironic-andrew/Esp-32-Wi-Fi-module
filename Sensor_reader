// ---- Compas ---->
String getCompassHeading() {
  
  static int16_t mx_min = 32767, mx_max = -32768;
  static int16_t my_min = 32767, my_max = -32768;
  static bool calibrated = false;

  Wire.beginTransmission(0x0C);
  Wire.write(0x02); 
  if (Wire.endTransmission() != 0) return "Compass Offline";
  
  Wire.requestFrom(0x0C, 1);
  if (Wire.read() & 0x01) { 
    
    Wire.beginTransmission(0x0C);
    Wire.write(0x03); 
    Wire.endTransmission(false);
    
    if (Wire.requestFrom(0x0C, 7) == 7) {
     
      uint8_t x_low  = Wire.read();
      uint8_t x_high = Wire.read();
      uint8_t y_low  = Wire.read();
      uint8_t y_high = Wire.read();
      uint8_t z_low  = Wire.read();
      uint8_t z_high = Wire.read();
      uint8_t st2    = Wire.read(); 
      
      if (!(st2 & 0x08)) { 
        
       
        int16_t raw_mx = (int16_t)(x_low | (x_high << 8));
        int16_t raw_my = (int16_t)(y_low | (y_high << 8));
        
        
        if (raw_mx < mx_min) mx_min = raw_mx;
        if (raw_mx > mx_max) mx_max = raw_mx;
        if (raw_my < my_min) my_min = raw_my;
        if (raw_my > my_max) my_max = raw_my;
        
        
        float offset_x = (mx_max + mx_min) / 2.0;
        float offset_y = (my_max + my_min) / 2.0;
        
        
        float cal_mx = (float)raw_mx - offset_x;
        float cal_my = (float)raw_my - offset_y;
        
        
        float heading = atan2(cal_my, cal_mx);
        float headingDegrees = heading * 180.0 / PI;
        
        if (headingDegrees < 0) headingDegrees += 360.0;
        
        
        if (mx_max - mx_min < 30 || my_max - my_min < 30) {
          return "Calibrating (Rotate Sensor)...";
        }
        

        if (headingDegrees >= 337.5 || headingDegrees < 22.5)   return "North (Північ) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 22.5 && headingDegrees < 67.5)     return "North-East (Північний Схід) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 67.5 && headingDegrees < 112.5)    return "East (Схід) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 112.5 && headingDegrees < 157.5)   return "South-East (Південний Схід) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 157.5 && headingDegrees < 202.5)   return "South (Південь) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 202.5 && headingDegrees < 247.5)   return "South-West (Південний Захід) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 247.5 && headingDegrees < 292.5)   return "West (Захід) [" + String(headingDegrees, 0) + "°]";
        if (headingDegrees >= 292.5 && headingDegrees < 337.5)   return "North-West (Північний Захід) [" + String(headingDegrees, 0) + "°]";
      }
    }
  }
  return "Calculating...";
}
