// ---- Orientation use BNO ---->
String getBNO_Orientation() {
  sensors_event_t orientationData;
  
  bno.getEvent(&orientationData, Adafruit_BNO055::VECTOR_EULER);
  
  float heading = orientationData.orientation.x; // Compas 0-360°
  float pitch   = orientationData.orientation.y; // Incline forward/backward
  float roll    = orientationData.orientation.z; // Incline leftward/rightward

  return "Heading: " + String(heading, 1) + "° | Pitch: " + String(pitch, 1) + "°";
}
