
#include <WiFi.h>
#include <WebServer.h>
#include "time.h"

#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>
#include <esp_wifi.h>

#include "Adafruit_VL53L0X.h"

Adafruit_VL53L0X lox = Adafruit_VL53L0X();

// Safe Pin Definitions (Explicitly matches your new wiring)
#define TRIG_PIN 3
#define ECHO_PIN 1

WebServer server(80);

void handleRoot();
void handleSyncTime();
void handleGetLiveValues();

void connection(){
  WiFi.disconnect(true);
  WiFi.mode(WIFI_AP);
  delay(100);

  uint8_t protocol_bitmap = WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N;
  esp_wifi_set_protocol(WIFI_IF_AP, protocol_bitmap);
  esp_wifi_set_bandwidth(WIFI_IF_AP, WIFI_BW_HT20); 
  
  #if defined(ESP_IDF_VERSION_MAJOR) && ESP_IDF_VERSION_MAJOR >= 4
    esp_wifi_set_ps(WIFI_PS_NONE); 
  #endif

  bool ap_status = WiFi.softAP("esp32", "20332077", 6, 0, 4);
  
  if(ap_status) {
    Serial.println("AP launched and VISIBLE.");
  } else {
    Serial.println("AP failed to launch.");
  }
  
  server.on("/", handleRoot);
  server.on("/sync-time", handleSyncTime);
  server.on("/api/data", handleGetLiveValues); 
  
  server.begin();
  Serial.print("Web Server started on IP: ");
  Serial.println(WiFi.softAPIP());
}

// Improved Ultrasonic function with explicit hardware cleanup
float getSensorDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(5);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  
  // 30000 microseconds = 30ms timeout (~5 meters max range)
  long duration = pulseIn(ECHO_PIN, HIGH, 30000); 
  
  if (duration <= 0 || duration > 35000) {
    return -1.0; 
  }
  
  float distanceCm = duration * 0.0343 / 2.0;
  
  // Sanity check for faulty readings
  if (distanceCm < 2.0 || distanceCm > 400.0) {
    return -1.0;
  }
  return distanceCm;
}

// Improved Laser Function with Status Logging
float getSensorDistance_laser(){
  VL53L0X_RangingMeasurementData_t measure;
  lox.rangingTest(&measure, false);
  
  // Status 0 means a valid laser return reflection trace profile
  if (measure.RangeStatus == 0) {
    return (float)measure.RangeMilliMeter / 10.0; 
  } else {
    return -1.0;
  }
}

String getLiveDateString() {
  struct tm timeinfo;
  if(!getLocalTime(&timeinfo)) {
    return "Time Not Set Yet (Syncing...)";
  }
  char dateBuffer[30];
  strftime(dateBuffer, sizeof(dateBuffer), "%Y-%m-%d %H:%M:%S", &timeinfo);
  return String(dateBuffer);
}

