// ---- Create local acces point ---->
void connection(){
  WiFi.disconnect(true);
  WiFi.mode(WIFI_AP);
  delay(100);

  uint8_t protocol_bitmap = WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N;
  esp_wifi_set_protocol(WIFI_IF_AP, protocol_bitmap);
  esp_wifi_set_bandwidth(WIFI_IF_AP, WIFI_BW_HT20); 
  
  #if defined(ESP_IDF_VERSION_MAJOR) && ESP_IDF_VERSION_MAJOR >= 4
    esp_wifi_set_ps(WIFI_PS_NONE); 
  #endif

  WiFi.softAP("esp32", "20332077", 6, 0, 4);
  
  server.on("/", handleRoot);
  server.on("/sync-time", handleSyncTime);
  server.on("/api/data", handleGetLiveValues); 
  
  server.begin();
}
