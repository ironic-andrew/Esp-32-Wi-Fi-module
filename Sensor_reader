  float ax = accelData.acceleration.x;
  float ay = accelData.acceleration.y;
  float az = accelData.acceleration.z;

  return "Acc X: " + String(ax, 2) + " | Y: " + String(ay, 2) + " | Z: " + String(az, 2);
}
