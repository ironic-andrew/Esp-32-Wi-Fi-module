void handleRoot() {
  String htmlResponse = String(HTML_TEMPLATE);
  float distance = getSensorDistance();
  float distance_laser = getSensorDistance_laser();
  String distanceStr = (distance < 0) ? "Out of Range" : String(distance, 1);
  String distanceStr_laser = (distance_laser < 0) ? "Out of Range" : String(distance_laser, 1);
  
  htmlResponse.replace("%LIVE_DATE%", getLiveDateString());
  htmlResponse.replace("%DISTANCE_HC%", distanceStr);
  htmlResponse.replace("%DISTANCE_GY%", distanceStr_laser);
  server.send(200, "text/html", htmlResponse);
}

void handleGetLiveValues() {
  float distance = getSensorDistance();
  float distance_laser = getSensorDistance_laser();
  String distanceStr = (distance < 0) ? "Out of Range" : String(distance, 1);
  String distanceStr_laser = (distance_laser < 0) ? "Out of Range" : String(distance_laser, 1);
  
  String json = "{";
  json += "\"distance_hc\":\"" + distanceStr + "\",";
  json += "\"distance_laser\":\"" + distanceStr_laser + "\",";
  json += "\"datetime\":\"" + getLiveDateString() + "\"";
  json += "}";
  server.send(200, "application/json", json);
}

void handleSyncTime() {
  if (server.hasArg("epoch")) {
    long long epoch = server.arg("epoch").toInt();
    struct timeval tv;
    tv.tv_sec = epoch;
    tv.tv_usec = 0;
    settimeofday(&tv, NULL);
    server.send(200, "text/plain", "OK");
  } else {
    server.send(400, "text/plain", "Bad Request");
  }
}

void setup() {
  Serial.begin(115200);
  delay(500); 
  
  // Force clean startup values for pins
  pinMode(TRIG_PIN, OUTPUT);
  digitalWrite(TRIG_PIN, LOW);
  pinMode(ECHO_PIN, INPUT);
  
  // Explicitly assign Standard SDA (8) and SCL (9) pins for I2C
  Wire.begin(8 , 9); 
  
  if (!lox.begin()) {
    Serial.println(F("CRITICAL ERROR: VL53L0X Laser wire issue or broken sensor hardware!"));
  } else {
    Serial.println(F("SUCCESS: VL53L0X Laser Found."));
  }
  
  connection();
}

void loop() {
  server.handleClient();
}
