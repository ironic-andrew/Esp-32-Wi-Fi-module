// ---- Real time function ---->
String getLiveDateString() {
  struct tm timeinfo;
  if(!getLocalTime(&timeinfo)) return "Time Not Set Yet (Syncing...)";
  char dateBuffer[30]; 
  strftime(dateBuffer, sizeof(dateBuffer), "%Y-%m-%d %H:%M:%S", &timeinfo);
  return String(dateBuffer);
}
