// ---- Setup ---->
void setup() {
  delay(1000); 
  
  // --- Set ultrasonic sensor --->
  pinMode(TRIG_PIN, OUTPUT);
  digitalWrite(TRIG_PIN, LOW);
  pinMode(ECHO_PIN, INPUT);
  // --------------

  // --- Set SDA and SCL, SetClock - 100000 --->
  Wire.begin(8, 9); 
  Wire.setClock(100000); 
  delay(200);
  // --------------

  // --- Set display configuration --->
  u8x8.begin();
  u8x8.setFlipMode(1);
  u8x8.setPowerSave(0); 
  u8x8.setFont(u8x8_font_chroma48medium8_r);
  u8x8.clear();
  u8x8.drawString(1, 3, "Initializing...");
  // --------------

  // --- Initialization MPU9250 --->
  Wire.beginTransmission(IMU_ADDRESS);
  Wire.write(0x6B); 
  Wire.write(0x00); 
  if (Wire.endTransmission() != 0) {
      log_e("Помилка ініціалізації MPU9250!");
  }
  delay(100); 
  // --------------

  // --- Calibrate date --->
  float sumX = 0, sumY = 0, rawX, rawY, rawZ;
  int validSamples = 0;
  
  for (int i = 0; i < 30; i++) {
    if (readAbsoluteIMU(rawX, rawY, rawZ)) {
      sumX += rawX;
      sumY += rawY;
      validSamples++;
    }
    delay(15);
  }
  if (validSamples > 0) {
    offsetX = sumX / (float)validSamples;
    offsetY = sumY / (float)validSamples;
  }
  delay(100); 
  // --------------
  
  // --- Set orientation use BNO --->
  Wire.beginTransmission(IMU_ADDRESS);
  Wire.write(0x6B); 
  Wire.write(0x00); 
  Wire.endTransmission();
  delay(10);
  // --------------

  // --- Set accelerometer use BNO --->
  Wire.beginTransmission(IMU_ADDRESS);
  Wire.write(0x37); 
  Wire.write(0x02); 
  Wire.endTransmission();
  delay(10);
  // --------------

  // --- Set magnetometer use BNO --->
  Wire.beginTransmission(0x0C); 
  Wire.write(0x0A); 
  Wire.write(0x16); 
  Wire.endTransmission();
  delay(10);
  // --------------

  // --- Set barometer --->
  if (!bmp.begin(0x76)) { 
    log_e("Не вдалося знайти барометр BMP280!");
  } else {
   
    bmp.setSampling(Adafruit_BMP280::MODE_NORMAL,     /* Режим роботи */
                    Adafruit_BMP280::SAMPLING_X2,     /* Температура */
                    Adafruit_BMP280::SAMPLING_X16,    /* Тиск */
                    Adafruit_BMP280::FILTER_X16,      /* Фільтрація шумів */
                    Adafruit_BMP280::STANDBY_MS_500); /* Час очікування */
  }
  // --------------

  // --- Try connection to BNO055 --->
  if(!bno.begin()) {
    Serial.print("BNO055 не знайдено! Перевірте підключення або адресу.");
  }

  delay(500);
  bno.setExtCrystalUse(true);
  // --------------  
  
  // --- Initialize i2c protocol --->
  lox.begin(0x29, false, &Wire); 
  // --------------  
  
  // --- Try create acces point --->
  connection();
  // -------------- 

  // --- Print massage that all good and platform rady to work --->
  u8x8.clear();
  u8x8.drawString(1,2, "Ready to work!");
  u8x8.drawString(1,4, "IP: 192.168.4.1");
