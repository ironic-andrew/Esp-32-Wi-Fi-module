// ---- Suport with date calibration few else function ---->
bool readAbsoluteIMU(float &x, float &y, float &z) {
  Wire.beginTransmission(IMU_ADDRESS);
  Wire.write(0x3B); 
  if (Wire.endTransmission(false) != 0) return false;

  if (Wire.requestFrom(IMU_ADDRESS, 6) != 6) return false;

  int16_t raw_x = (Wire.read() << 8) | Wire.read();
  int16_t raw_y = (Wire.read() << 8) | Wire.read();
  int16_t raw_z = (Wire.read() << 8) | Wire.read();

  x = (float)raw_x / 16384.0;
  y = (float)raw_y / 16384.0;
  z = (float)raw_z / 16384.0;
  
  return true;
}
