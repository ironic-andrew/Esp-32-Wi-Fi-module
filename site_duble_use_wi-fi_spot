// ---- mode1 ----
// --- Check command ---
void handleCommand() {
  if (!mode1) {
    server.send(200, "text/plain", "Manual mode disabled");
    return;
  }

  String message = server.arg("dir");
  Serial.print("Отримано команду: ");
  Serial.println(message);

  if(message == "forward_left")        Motors(50, 0, 80, 0);
  else if(message == "forward_right")  Motors(80, 0, 50, 0);
  else if(message == "backward_left")  Motors(0, 50, 0, 80);
  else if(message == "backward_right") Motors(0, 80, 0, 50);
  else if(message == "forward")        Motors(80, 0, 80, 0);
  else if(message == "backward")       Motors(0, 80, 0, 80);
  else if(message == "left")           Motors(0, 0, 80, 0);
  else if(message == "right")          Motors(80, 0, 0, 0);
  else                                 Motors(0, 0, 0, 0); // stop

  server.send(200, "text/plain", "OK");
}

// ---- Change mode ----
// --- mode1 ---
void handleMode1() {
  mode1 = true; mode2 = false;

  analogWrite(motors[0], 0);
  analogWrite(motors[1], 0);
  analogWrite(motors[2], 0);
  analogWrite(motors[3], 0);

  
  Motors((short)0, (short)0); 

  u8x8.clear();
  Serial.println("Обраний <mode1>. Усі ШІМ-піни занулені!");
  u8x8.drawString(1, 4, "Ready to work!");
  server.send(200, "text/plain", "Mode 1 Active");
}

// --- mode2 ---
void handleMode2() {
  
  for(int i = 0; i < 8; i++) {
    sensor_max[i] = 0;
    sensor_min[i] = 10000;
  }
  integral = 0;
  lastError = 0;
  calibrate_marker = true; 

  mode2 = true; mode1 = false; 
  Serial.println("Обраний <mode2>");
  server.send(200, "text/plain", "Mode 2 Active");
}

// --- Sethings hotspot and website ---
void connection(){
  WiFi.mode(WIFI_AP);

  uint8_t protocol_bitmap = WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N;
  esp_wifi_set_protocol(WIFI_IF_AP, protocol_bitmap);
  esp_wifi_set_bandwidth(WIFI_IF_AP, WIFI_BW_HT20); 
  
  #if defined(ESP_IDF_VERSION_MAJOR) && ESP_IDF_VERSION_MAJOR >= 4
    esp_wifi_set_ps(WIFI_PS_NONE); 
  #endif

  WiFi.softAP("esp32", "20332077", 6, 0, 8);
  Serial.println("AP live.");
  
  server.on("/", handleRoot);
  server.on("/cmd", handleCommand);
  server.on("/mode1", handleMode1);
  server.on("/mode2", handleMode2);
  
  server.begin();
  Serial.println("Web Server started on IP: 192.168.4.1");
  u8x8.drawString(0, 3, "Web Server Live");
  u8x8.drawString(0, 5, "IP: 192.168.4.1");
}

// ---- mode2 ----
// --- Calibrate ---
void calibrate() {
  long startTime = millis();
  Motors(80, -80); 
  u8x8.clear();
  u8x8.drawString(3, 3, "Calibration...");

  int8_t current_step = 1;

  while(millis() - startTime < 3000) {
    server.handleClient(); 
    if (!mode2) { 
      break; 
    }

    long current_time = millis() - startTime;
    if(current_time < 1000 && current_step == 1){ u8x8.drawString(8, 5, "3"); current_step = 2; }
    else if(current_time >= 1000 && current_step == 2){ u8x8.drawString(8, 5, "2"); current_step = 3; }
    else if(current_time >= 2000 && current_step == 3){ u8x8.drawString(8, 5, "1"); current_step = 4; }
    
    for(int8_t i = 0; i < 8; ++i) {
      short current_val = analogRead(sensors[i]);
      if(current_val < sensor_min[i]) { sensor_min[i] = current_val; }
      if(current_val > sensor_max[i]) { sensor_max[i] = current_val; }
    }
  } 

  Motors(0, 0); 
  delay(100);
  u8x8.clear();
  u8x8.drawString(3, 3, "Completed!");
  delay(500);
  u8x8.clear();
}

// --- Sensor read ---
int sensorsRead(){
    short sensors_read[8]; 
    long sum = 0, count = 0, raw = 0, calibrated = 0, position = 0;

    // -- read and calibrate sensors --
    for(int i = 0; i < 8; ++i){
      raw = analogRead(sensors[i]);
      
      if(sensor_max[i] == sensor_min[i]) sensor_max[i] += 1; 
      
      calibrated = map(raw, sensor_min[i], sensor_max[i], 0, 1000); 
      calibrated = constrain(calibrated, 0, 1000); 

      
      if(i == 7) calibrated -= 100;
      if(i == 5) calibrated += 70;
      if (calibrated < 200) calibrated = 0;

      
      sensors_read[i] = calibrated;

      sum += (long)calibrated * weights[i];
      count += calibrated;
    }

    // -- print passive/active sensors
    int8_t disp_col = 2; 
    for(int8_t i = 7; i >= 0; --i){
      disp_col += 1; 

      if(sensors_read[i] >= 850){
        u8x8.drawString(disp_col, 4, "+"); 
      } else {
        u8x8.drawString(disp_col, 4, "-"); 
      }
    } 
    
    // 3. Розрахунок помилки для PID
    if (count == 0) return lastError;
    position = sum / count;  
    return position;
}

// ---- Apply motors for mode2 ----
void Motors(short leftSpeed, short rightSpeed){
  leftSpeed = constrain(leftSpeed, -255, 255);
  rightSpeed = constrain(rightSpeed, -255, 255);

  if(leftSpeed >= 0){ analogWrite(motors[0], leftSpeed); analogWrite(motors[1], 0); }
  else { analogWrite(motors[0], 0); analogWrite(motors[1], abs(leftSpeed)); }

  if(rightSpeed >= 0){ analogWrite(motors[2], rightSpeed); analogWrite(motors[3], 0); }
  else { analogWrite(motors[2], 0); analogWrite(motors[3], abs(rightSpeed)); }
}

// ----- setup -----
void setup() {
  Serial.begin(115200);

  pinMode(motors[0], OUTPUT);
  pinMode(motors[1], OUTPUT);
  pinMode(motors[2], OUTPUT);
  pinMode(motors[3], OUTPUT);

  delay(1000); 
  Serial.println("\n--- Старт програми ---");

  u8x8.begin();
  u8x8.setFlipMode(1);
  u8x8.setPowerSave(0); 
  u8x8.setFont(u8x8_font_chroma48medium8_r);
  u8x8.clear();

  connection();
}

// ----- loop -----
void loop() {
  server.handleClient(); 

  // --- Check mode 2 status ---
  if (mode2) {
    if (calibrate_marker) {
      calibrate();
      calibrate_marker = false;
    }

    if (!mode2) return; 

    short position = sensorsRead(); 
    float error = position; 

    float P = error;
    integral += error;
    integral = constrain(integral, -2000, 2000); 
    
    float D = error - lastError;
    lastError = error;

    float steering = (Kp * P) + (Ki * integral) + (Kd * D);

    short lSpeed = baseSpeed + steering;
    short rSpeed = baseSpeed - steering;

    Motors(lSpeed, rSpeed);  

    if (millis() - lastDisplayTime > 300) {
      lastDisplayTime = millis();
    }
  }
}
