<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Робот-Матриця 6х6</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-color: #f4f4f9;
            margin-top: 30px;
        }
        h2 { color: #333; }
        .matrix {
            display: grid;
            /* Налаштування сітки на 6 колонок */
            grid-template-columns: repeat(6, 55px);
            grid-gap: 8px;
            margin-bottom: 20px;
        }
        .cell-label {
            width: 55px;
            height: 55px;
            background-color: #fff;
            border: 2px solid #ccc;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            font-weight: bold;
            user-select: none;
            transition: all 0.2s;
            position: relative;
            font-size: 12px;
        }
        .cell-label input {
            display: none;
        }
        .cell-label:has(input:checked) { 
            background-color: #4CAF50;
            color: white;
            border-color: #45a049;
        }
        /* Номер кроку на кнопці */
        .cell-label .step-num {
            font-size: 9px;
            color: #ffeb3b;
            margin-top: 2px;
        }
        .info {
            color: #666;
            font-size: 14px;
            margin-bottom: 20px;
        }
        .btn { 
            background: #6c757d; 
            color: #f8f9fa; 
            border: 1px solid #6c757d; 
            padding: 0.5rem 2rem; 
            font-size: 1.2rem; 
            border-radius: 0.375rem; 
            cursor: pointer; 
            transition: 0.15s; 
            outline: none; 
        }
        .btn:active {
            background-color: #45a049;
        }
    </style>
</head>
<body>

    <h2>Інтерактивна матриця маршруту 6х6</h2>
    <p class="info">Натискайте клітинки ПОСЛІДОВНО, як має їхати робот</p>

    <div class="matrix" id="matrix"></div>
       
    <button id="btn" type="button" class="btn">Start</button>

    <script>
        // Динамічна генерація матриці 6х6
        const matrixContainer = document.getElementById('matrix');
        const MATRIX_SIZE = 6;

        for (let y = 0; y < MATRIX_SIZE; y++) {
            for (let x = 0; x < MATRIX_SIZE; x++) {
                const label = document.createElement('label');
                label.className = 'cell-label';
                label.id = `cell-${x}-${y}`;
                label.innerHTML = `
                    <input type="checkbox" data-x="${x}" data-y="${y}">
                    ${x},${y}
                    <span class="step-num"></span>
                `;
                matrixContainer.appendChild(label);
            }
        }

        // Логіка роботи маршруту
        let userPath = []; 
        let routeX = []; 
        let routeY = [];
        
        const checkboxes = document.querySelectorAll('.matrix input');
        const btn = document.getElementById('btn');

        function handleBtnStart() {
            sendRouteToESP();
        }
            
        btn.addEventListener('mousedown', handleBtnStart);
        btn.addEventListener('touchstart', (event) => {
            event.preventDefault(); 
            handleBtnStart();
        });
        
        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', (event) => {
                const x = parseInt(event.target.getAttribute('data-x'));
                const y = parseInt(event.target.getAttribute('data-y'));

                if (event.target.checked) {
                    userPath.push({x, y});
                } else {
                    userPath = userPath.filter(point => !(point.x === x && point.y === y));
                }

                updateStepLabels();
                
                routeX = userPath.map(p => p.x);
                routeY = userPath.map(p => p.y);

                console.clear();
                console.log("Послідовний маршрут користувача:");
                console.log(userPath.map(p => `(${p.x},${p.y})`).join(" -> "));
            });
        });

        function updateStepLabels() {
            checkboxes.forEach(cb => {
                cb.parentElement.querySelector('.step-num').innerText = "";
            });
            
            userPath.forEach((point, index) => {
                const label = document.querySelector(`.matrix input[data-x="${point.x}"][data-y="${point.y}"]`);
                if (label) {
                    label.parentElement.querySelector('.step-num').innerText = `[Кр. ${index + 1}]`;
                }
            });
        }

        function sendRouteToESP() {
            if (routeX.length === 0) {
                alert("Маршрут порожній! Виберіть клітинки.");
                return;
            }
            const xStr = routeX.join(",");
            const yStr = routeY.join(",");

            const xhr = new XMLHttpRequest();
            xhr.open("GET", `/send_route?x=${xStr}&y=${yStr}`, true);
            
            xhr.onreadystatechange = function () {
                if (xhr.readyState === 4 && xhr.status === 200) {
                    console.log("ESP32 прийняв маршрут:", xhr.responseText);
                    resetMatrix();
                }
            };
            xhr.send();
        }

        function resetMatrix() {
            checkboxes.forEach(cb => cb.checked = false);
            userPath = [];
            routeX = [];
            routeY = [];
            updateStepLabels();
        }
    </script>
</body>
</html>
