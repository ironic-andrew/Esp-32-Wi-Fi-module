// --- Giroscope --->
String getIMUOrientation(){
  float rawX = 0, rawY = 0, rawZ = 0;
  float threshold = 0.25; 
  String position = "Stable / Flat";

  if (readAbsoluteIMU(rawX, rawY, rawZ)) {
    float calX = rawX - offsetX;
    float calY = rawY - offsetY;
    
    smoothX = (smoothX * 0.7) + (calX * 0.3);
    smoothY = (smoothY * 0.7) + (calY * 0.3);
    
    if (abs(smoothX) > abs(smoothY)) {
      if (smoothX > threshold)       position = "Collision Left";
      else if (smoothX < -threshold) position = "Collision Right";
    } else {
      if (smoothY > threshold)       position = "Collision Front";
      else if (smoothY < -threshold) position = "Collision Back";
    }
  } else {
    position = "IMU Sensor Offline";
  }
  return position;
}
