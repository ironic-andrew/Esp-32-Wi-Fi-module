// --- Laser sensor --->
float getSensorDistance_laser(){
  VL53L0X_RangingMeasurementData_t measure;
  lox.rangingTest(&measure, false);
  
  if (measure.RangeStatus == 0) {
    float result = (float)measure.RangeMilliMeter / 10.0;
    if(result <= 0.5 || result > 150.0) return -1.0; 
    return result;
  } else {
    return -1.0;
  }
}
