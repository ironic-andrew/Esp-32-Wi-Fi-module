// --- Barometer --->
String getBarometerData() {
  float temp = bmp.readTemperature();
  if (isnan(temp) || temp < -40.0) {
    return "Barometer Offline";
  }
  float pressurePa = bmp.readPressure(); 
  float pressureMmHg = pressurePa / 133.3224; 

  return "T: " + String(temp, 1) + "°C | P: " + String(pressureMmHg, 1) + " mmHg";
}
