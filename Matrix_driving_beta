// ---- Proccesing drive ---->
int current_dir = 0; 

void road_drive(){
  if (routeSize < 2) {
    Serial.println("Замало точок для руху.");
    return;
  }
  
  //comment it if you want`t that robot have memmory
  current_dir = 0; 

  for(int i = 0; i < routeSize - 1; i++) {
    int deltaX = robotX[i + 1] - robotX[i]; 
    int deltaY = robotY[i + 1] - robotY[i]; 

    
    int target_dir = current_dir; 
    if (deltaY < 0)       target_dir = 0; // Вгору (-Y)
    else if (deltaX > 0)  target_dir = 1; // Вправо (+X)
    else if (deltaY > 0)  target_dir = 2; // Вниз (+Y)
    else if (deltaX < 0)  target_dir = 3; // Вліво (-X)

    Serial.printf("Крок %d: з (%d,%d) до (%d,%d) | Компас: %d -> Ціль: %d\n", 
                  i, robotX[i], robotY[i], robotX[i+1], robotY[i+1], current_dir, target_dir);


    int diff = (target_dir - current_dir + 4) % 4;
    
    
    if (diff == 1) {  
      Serial.println("-> Поворот направо на 90°");
      u8x8.drawString(1, 5, "Turn RIGHT       ");
      Motors(60, 0, 0, 60); 
      delay(380);          
      current_dir = target_dir; 
      
      Motors(0, 0, 0, 0);   
      delay(200);
    } 
    else if (diff == 3) {
      Serial.println("-> Поворот наліво на 90°");
      u8x8.drawString(1, 5, "Turn LEFT        ");
      Motors(0, 60, 60, 0); 
      delay(380);           
      current_dir = target_dir;
      
      Motors(0, 0, 0, 0);
      delay(200);
    } 
    else if (diff == 2) {
      Serial.println("-> Розварот на 180°");
      u8x8.drawString(1, 5, "Turn 180°        ");
      Motors(60, 0, 0, 60); 
      delay(680);           
      current_dir = target_dir;
      
      Motors(0, 0, 0, 0);
      delay(200);
    } 
    else {
      
      u8x8.drawString(1, 5, "Go Straight     ");
    }

    
    Serial.println("-> Рух ВПЕРЕД у наступну клітинку");
    Motors(60, 0, 60, 0); 
    delay(600); 
    
    
    Motors(0, 0, 0, 0);
    delay(200);
  }

  Serial.println("Маршрут завершено. Зупинка.");
  Motors(0, 0, 0, 0);
  u8x8.clear();
}
// --------------

// ---- Setup ---->
void setup() {
  Serial.begin(115200);
  
  // --- Display initializetion --->
  u8x8.begin();
  u8x8.setFlipMode(1);
  u8x8.setPowerSave(0); 
  u8x8.setFont(u8x8_font_chroma48medium8_r);
  u8x8.clear();
  // ------------

  for(int i = 0; i < 4; i++) {
    pinMode(motors[i], OUTPUT);
  }
  connection();
}
// --------------

// ---- Loop ---->
void loop() {
  server.handleClient(); 

  if(mode){
    mode = false;
    road_drive();
  }
}
