
#include <WiFi.h>
#include <WebServer.h>
#include "time.h"

#include <Arduino.h>
#include <Wire.h>
#include <esp_wifi.h>

#include "Adafruit_VL53L0X.h"

Adafruit_VL53L0X lox = Adafruit_VL53L0X();

// Fixed Hardware Platform Pins
#define TRIG_PIN 3
#define ECHO_PIN 1

// Target I2C addresses from your scanner results
#define IMU_ADDRESS 0x28 
#define LASER_ADDRESS 0x29

WebServer server(80);

// Smooth Filtering
float smoothX = 0.0, smoothY = 0.0;
float offsetX = 0.0, offsetY = 0.0;

void handleRoot();
void handleSyncTime();
void handleGetLiveValues();

void connection(){
  WiFi.disconnect(true);
  WiFi.mode(WIFI_AP);
  delay(100);

  uint8_t protocol_bitmap = WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N;
  esp_wifi_set_protocol(WIFI_IF_AP, protocol_bitmap);
  esp_wifi_set_bandwidth(WIFI_IF_AP, WIFI_BW_HT20); 
  
  #if defined(ESP_IDF_VERSION_MAJOR) && ESP_IDF_VERSION_MAJOR >= 4
    esp_wifi_set_ps(WIFI_PS_NONE); 
  #endif

  WiFi.softAP("esp32", "20332077", 6, 0, 4);
  
  server.on("/", handleRoot);
  server.on("/sync-time", handleSyncTime);
  server.on("/api/data", handleGetLiveValues); 
  
  server.begin();
}

float getSensorDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2); 
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  
  long duration = pulseIn(ECHO_PIN, HIGH, 15000); 
  if (duration <= 0 || duration > 25000) return -1.0; 
  
  float distanceCm = duration * 0.0343 / 2.0;
  if (distanceCm < 2.0 || distanceCm > 400.0) return -1.0;
  return distanceCm;
}

float getSensorDistance_laser(){
  VL53L0X_RangingMeasurementData_t measure;
  lox.rangingTest(&measure, false);
  
  if (measure.RangeStatus == 0) {
    float result = (float)measure.RangeMilliMeter / 10.0;
    if(result <= 0.5 || result > 150.0) return -1.0; 
    return result;
  } else {
    return -1.0;
  }
}


bool readAbsoluteIMU(float &x, float &y, float &z) {
  Wire.beginTransmission(IMU_ADDRESS);
  
  Wire.write(0x08); 
  if (Wire.endTransmission(false) != 0) return false;

  if (Wire.requestFrom(IMU_ADDRESS, 6) != 6) return false;

  
  int16_t raw_x = (Wire.read() | (Wire.read() << 8));
  int16_t raw_y = (Wire.read() | (Wire.read() << 8));
  int16_t raw_z = (Wire.read() | (Wire.read() << 8));

  
  x = (float)raw_x / 100.0;
  y = (float)raw_y / 100.0;
  z = (float)raw_z / 100.0;
  return true;
}

String getIMUOrientation(){
  float rawX = 0, rawY = 0, rawZ = 0;
  float threshold = 0.25; 
  String position = "Stable / Flat";

  if (readAbsoluteIMU(rawX, rawY, rawZ)) {
    float calX = rawX - offsetX;
    float calY = rawY - offsetY;
    
   
    smoothX = (smoothX * 0.7) + (calX * 0.3);
    smoothY = (smoothY * 0.7) + (calY * 0.3);
    
    if (abs(smoothX) > abs(smoothY)) {
      if (smoothX > threshold)       position = "Collision Left";
      else if (smoothX < -threshold) position = "Collision Right";
    } else {
      if (smoothY > threshold)       position = "Collision Front";
      else if (smoothY < -threshold) position = "Collision Back";
    }
  } else {
    position = "IMU Sensor Offline";
  }
  return position;
}

String getLiveDateString() {
  struct tm timeinfo;
  if(!getLocalTime(&timeinfo)) return "Time Not Set Yet (Syncing...)";
  char dateBuffer[30]; 
  strftime(dateBuffer, sizeof(dateBuffer), "%Y-%m-%d %H:%M:%S", &timeinfo);
  return String(dateBuffer);
}

